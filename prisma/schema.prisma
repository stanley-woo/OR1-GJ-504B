generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// User maps the app identity
model User {
  id String @id @default(cuid()) // This is the primary key for this table
  clerkId String @unique
  email String @unique
  firstName  String?
  lastName  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  account BrokerageAccount?
}

// BrokerageAccount maps paper-trading state. It acts as the anchor of the paper-trading logic.
model BrokerageAccount {
  id String @id @default(cuid()) // This is the primary key for this table
  status AccountStatus @default(ACTIVE)
  baseCurrency String @default("USD")
  buyingPower Decimal @default(10000.00) @db.Decimal(18,2)
  cashBalance Decimal @default(10000.00) @db.Decimal(18,2)
  openedAt DateTime @default(now())
  createdAt DateTime @default(now())
  updatedAt  DateTime @updatedAt
  userId String @unique
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  positions         Position[]
  transactions      Transaction[]
  snapshots         PortfolioSnapshot[] 
}

model Position {
  id String @id @default(cuid())
  symbol String
  companyName String
  exchange String @default("NASDAQ")
  shares Decimal @db.Decimal(18, 6)
  avgCostBasis Decimal @db.Decimal(18, 2)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  accountId String
  account BrokerageAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@unique([accountId, symbol])
}

model Transaction {
  id String @id @default(cuid())
  type TransactionType
  symbol String
  companyName String
  shares Decimal @db.Decimal(18, 6)
  pricePerShare Decimal @db.Decimal(18, 2)
  totalAmount Decimal @db.Decimal(18, 2)
  executedAt DateTime @default(now())
  accountId String
  account BrokerageAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
}

model PortfolioSnapshot {
  id String @id @default(cuid())
  portfolioValue Decimal @db.Decimal(18,2)
  snapshotDate DateTime @default(now())
  accountId String
  account BrokerageAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)



  @@index([accountId, snapshotDate])
}

enum AccountStatus {
  ACTIVE
  SUSPENDED
  CLOSED
}

enum TransactionType {
  BUY
  SELL
}
